# HuggingFace model ID used during ONNX export
GENDER_MODEL_ID=prithivMLmods/Common-Voice-Gender-Detection

# Path to directory where ONNX artifacts are saved/loaded
GENDER_ONNX_DIR=onnx_model

# Export precision: fp16 (recommended for GPU) or fp32
GENDER_PRECISION=fp16

# Maximum number of requests grouped into one inference batch
GENDER_MAX_BATCH_SIZE=32

# Seconds to wait before dispatching an incomplete batch (lower = less latency, higher = more throughput)
GENDER_BATCH_TIMEOUT=0.005

# Number of parallel ORT inference sessions per GPU (2 reduces p95 significantly)
GENDER_WORKERS=2

# Host address the service binds to
GENDER_HOST=0.0.0.0

# Port the service listens on
GENDER_PORT=8000

# Directory for log files (per-process: gender-<pid>.log, rotated 100 MB x 5).
# Leave unset to log to stdout only (recommended under Docker).
# GENDER_LOG_DIR=/app/logs
